
    if(window.adMultimediasInfo.homeStaging.length) {
        
    var paths = [
        '/react/homestaging/dist/main.ac28aca20c121055a6f1.js','/react/homestaging/dist/runtime.ac28aca20c121055a6f1.js','/react/homestaging/dist/npm.idealista.ac28aca20c121055a6f1.js','/react/homestaging/dist/npm..pnpm.ac28aca20c121055a6f1.js'
    ];

    var baseURI = ('config' in window) ? window.config.staticsBaseUri : '';
    var createScriptNodeByPath = function (path) {
        var node = document.createElement('script');
        node.src = path;
        return node;
    };

    var createLinkNodeFromFile = function (file) {
        var node = document.createElement('link');
        node.rel = 'stylesheet';
        node.type = 'text/css';
        node.media = 'all';
        node.href = file;
        return node;
    };

    loadCssFile = function (file) {
        var linkNode = createLinkNodeFromFile(file);
        document.head.appendChild(linkNode);
    };

    paths.forEach(function (path) {
        var scriptPath = baseURI + path;
        document.body.appendChild(createScriptNodeByPath(scriptPath));
    });

    var cssFile = 'main.ac28aca20c121055a6f1.css';
    if(cssFile) {
        loadCssFile(baseURI + '/react/homestaging/dist/main.ac28aca20c121055a6f1.css');
    }

    }
