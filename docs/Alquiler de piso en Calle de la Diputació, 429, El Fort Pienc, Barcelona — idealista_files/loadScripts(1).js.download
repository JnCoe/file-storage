
    if(window.config.isDetailCdnEnabled || window.config.hasToShowRecommendations) {
        
    var paths = [
        '/react/detailWithSuggestions/dist/main.482156c79d3afa72d52c.js','/react/detailWithSuggestions/dist/runtime.482156c79d3afa72d52c.js','/react/detailWithSuggestions/dist/npm.idealista.482156c79d3afa72d52c.js','/react/detailWithSuggestions/dist/npm..pnpm.482156c79d3afa72d52c.js'
    ];

    var baseURI = ('config' in window) ? window.config.staticsBaseUri : '';
    var createScriptNodeByPath = function (path) {
        var node = document.createElement('script');
        node.src = path;
        return node;
    };

    var createLinkNodeFromFile = function (file) {
        var node = document.createElement('link');
        node.rel = 'stylesheet';
        node.type = 'text/css';
        node.media = 'all';
        node.href = file;
        return node;
    };

    loadCssFile = function (file) {
        var linkNode = createLinkNodeFromFile(file);
        document.head.appendChild(linkNode);
    };

    paths.forEach(function (path) {
        var scriptPath = baseURI + path;
        document.body.appendChild(createScriptNodeByPath(scriptPath));
    });

    var cssFile = 'main.482156c79d3afa72d52c.css';
    if(cssFile) {
        loadCssFile(baseURI + '/react/detailWithSuggestions/dist/main.482156c79d3afa72d52c.css');
    }

    }
